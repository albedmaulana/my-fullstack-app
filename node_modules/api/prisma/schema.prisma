// apps/api/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════
// 1. ADMIN (existing — enhanced)
// ═══════════════════════════════════════════
model Admin {
  id        Int      @id @default(autoincrement())
  username  String   @unique @db.VarChar(100)
  password  String   @db.VarChar(255)
  nama      String   @db.VarChar(150)
  foto      String?  @default("https://images.unsplash.com/photo-1472099645785-5658abf4ff4e") @db.VarChar(500)
  createdAt DateTime @default(now())

  berita Berita[]

  @@map("admins")
}

// ═══════════════════════════════════════════
// 1b. USER (visitor accounts)
// ═══════════════════════════════════════════
model User {
  id        Int      @id @default(autoincrement())
  nama      String   @db.VarChar(150)
  email     String   @unique @db.VarChar(200)
  phone     String?  @db.VarChar(20)
  password  String   @db.VarChar(255)
  foto      String?  @default("https://images.unsplash.com/photo-1535713875002-d1d0cf377fde") @db.VarChar(500)
  createdAt DateTime @default(now())

  @@map("users")
}

// ═══════════════════════════════════════════
// 2. MENU (existing — enhanced)
// ═══════════════════════════════════════════
model Menu {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(255)
  day         String   @db.VarChar(50)
  date        DateTime @db.Date
  description String?  @db.Text
  energy      Int?     @default(0)
  protein     Int?     @default(0)
  karbo       Int?     @default(0)
  lemak       Int?     @default(0)
  category    String?  @default("Makan Siang") @db.VarChar(100)
  status      String?  @default("Draft") @db.VarChar(50)
  img         String?  @db.VarChar(500)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("menus")
}

// ═══════════════════════════════════════════
// 3. STATISTIK WILAYAH (existing — enhanced)
// ═══════════════════════════════════════════
model StatistikWilayah {
  id                Int      @id @default(autoincrement())
  wilayah           String   @unique @db.VarChar(150)
  total_porsi       Int      @default(0)
  jangkauan_sekolah Int      @default(0)
  target_penerima   Int      @default(0)
  realisasi_porsi   Int      @default(0)
  pertumbuhan       String   @default("+0%") @db.VarChar(20)
  status            String   @default("PROSES") @db.VarChar(50)
  updatedAt         DateTime @updatedAt

  @@map("statistik_wilayah")
}

// ═══════════════════════════════════════════
// 4. BERITA (NEW)
// ═══════════════════════════════════════════
model Berita {
  id          Int       @id @default(autoincrement())
  judul       String    @db.VarChar(300)
  slug        String    @unique @db.VarChar(350)
  ringkasan   String    @db.Text
  konten      String    @db.LongText
  gambar      String?   @db.VarChar(500)
  kategori    String    @default("Edukasi") @db.VarChar(100)
  status      String    @default("Draft") @db.VarChar(50)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  authorId Int
  author   Admin @relation(fields: [authorId], references: [id])

  @@map("berita")
}

// ═══════════════════════════════════════════
// 5. GALERI DOKUMENTASI (NEW)
// ═══════════════════════════════════════════
model GaleriDokumentasi {
  id        Int      @id @default(autoincrement())
  judul     String   @db.VarChar(255)
  deskripsi String?  @db.Text
  gambar    String   @db.VarChar(500)
  lokasi    String?  @db.VarChar(200)
  tahun     Int?
  createdAt DateTime @default(now())

  @@map("galeri_dokumentasi")
}

// ═══════════════════════════════════════════
// 6. ASPIRASI / PESAN MASUK (NEW)
// ═══════════════════════════════════════════
model Aspirasi {
  id        Int      @id @default(autoincrement())
  nama      String   @db.VarChar(200)
  email     String?  @db.VarChar(200)
  kategori  String   @default("saran") @db.VarChar(50)
  pesan     String   @db.Text
  status    String   @default("BARU") @db.VarChar(50)
  createdAt DateTime @default(now())

  @@map("aspirasi")
}

// ═══════════════════════════════════════════
// 7. NEWSLETTER SUBSCRIBER (NEW)
// ═══════════════════════════════════════════
model NewsletterSubscriber {
  id        Int      @id @default(autoincrement())
  email     String   @unique @db.VarChar(200)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("newsletter_subscribers")
}

// ═══════════════════════════════════════════
// 8. ACTIVITY LOG (NEW)
// ═══════════════════════════════════════════
model ActivityLog {
  id        Int      @id @default(autoincrement())
  entity    String   @db.VarChar(100)
  action    String   @db.VarChar(100)
  detail    String   @db.Text
  icon      String?  @default("history") @db.VarChar(50)
  createdAt DateTime @default(now())

  @@map("activity_log")
}
